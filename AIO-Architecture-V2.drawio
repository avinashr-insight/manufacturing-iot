          </mxGeometry>
        </mxCell>
        <mxCell id="fs-v5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;" value="OT switch ARP table&#xa;updated — VIP MAC&#xa;addresses now point&#xa;to Node 2" vertex="1">
          <mxGeometry height="76" width="230" x="1112" y="500" as="geometry" />
        </mxCell>
        <mxCell id="arr-fv5" edge="1" parent="1" style="endArrow=block;endFill=1;html=1;strokeColor=#82b366;strokeWidth=2;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="fs-v6">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1342" y="538" as="sourcePoint" />
            <mxPoint x="1352" y="538" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="fs-v6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;align=center;" value="Clients reconnect to&#xa;same VIP addresses&#xa;No config change needed&#xa;DONE — ~1-2 seconds" vertex="1">
          <mxGeometry height="76" width="414" x="1360" y="500" as="geometry" />
        </mxCell>
        <mxCell id="fs-sep" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;align=center;" value="SEPARATE AND INDEPENDENT EVENT — Pod rescheduling begins only after kubelet heartbeat timeout (~40s after node failure)" vertex="1">
          <mxGeometry height="22" width="1748" x="26" y="584" as="geometry" />
        </mxCell>
        <mxCell id="fs-pod-lbl" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;align=center;" value="Pod Reschedule&#xa;~40-60 seconds" vertex="1">
          <mxGeometry height="76" width="86" x="26" y="614" as="geometry" />
        </mxCell>
        <mxCell id="fs-p1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=center;" value="kubelet heartbeat&#xa;timeout — K3s detects&#xa;Node 1 unresponsive&#xa;(~40s after failure)" vertex="1">
          <mxGeometry height="76" width="380" x="120" y="614" as="geometry" />
        </mxCell>
        <mxCell id="arr-fp1" edge="1" parent="1" style="endArrow=block;endFill=1;html=1;strokeColor=#6c8ebf;strokeWidth=2;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="fs-p2">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="500" y="652" as="sourcePoint" />
            <mxPoint x="514" y="652" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="fs-p2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=center;" value="K3s scheduler marks&#xa;Node 1 pods as failed&#xa;Pods queued for&#xa;rescheduling" vertex="1">
          <mxGeometry height="76" width="380" x="522" y="614" as="geometry" />
        </mxCell>
        <mxCell id="arr-fp2" edge="1" parent="1" style="endArrow=block;endFill=1;html=1;strokeColor=#6c8ebf;strokeWidth=2;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="fs-p3">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="902" y="652" as="sourcePoint" />
            <mxPoint x="916" y="652" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="fs-p3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=center;" value="Pods rescheduled to&#xa;Node 2 or Node 3&#xa;containerd pulls&#xa;and starts containers" vertex="1">
          <mxGeometry height="76" width="380" x="924" y="614" as="geometry" />
        </mxCell>
        <mxCell id="arr-fp3" edge="1" parent="1" style="endArrow=block;endFill=1;html=1;strokeColor=#6c8ebf;strokeWidth=2;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="fs-p4">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1304" y="652" as="sourcePoint" />
            <mxPoint x="1318" y="652" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="fs-p4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;align=center;" value="Pods become Ready&#xa;Services fully resume&#xa;DONE — ~40-60 seconds&#xa;after node failure" vertex="1">
          <mxGeometry height="76" width="448" x="1326" y="614" as="geometry" />
        </mxCell>
        <mxCell id="fs-key" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;align=left;" value="VIPs moved in ~1-2s.  Pods resumed in ~40-60s.  Clients experience a brief TCP reconnect — not a 40-60s outage — because the VIP is already available on Node 2 before pods are rescheduled." vertex="1">
          <mxGeometry height="24" width="1748" x="26" y="698" as="geometry" />
        </mxCell>
        <mxCell id="cfg-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f7f0;strokeColor=#9673a6;strokeWidth=2;" value="" vertex="1">
          <mxGeometry height="158" width="860" x="20" y="776" as="geometry" />
        </mxCell>
        <mxCell id="cfg-hdr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;align=left;" value="Kube-VIP Configuration and Deployment" vertex="1">
          <mxGeometry height="30" width="860" x="20" y="776" as="geometry" />
        </mxCell>
        <mxCell id="cfg-content" parent="1" style="text;html=1;fontSize=11;align=left;fillColor=none;strokeColor=none;verticalAlign=top;fontFamily=Courier New;" value="&lt;font face=&quot;Helvetica&quot; style=&quot;font-size: 10px;&quot;&gt;Deployed as:    DaemonSet — automatically runs on all 3 nodes&lt;br&gt;Mode:           L2 ARP — no BGP · no switch config required · works on any L2 switch&lt;br&gt;Election:       Kubernetes leader election API (lease object in kube-system namespace)&lt;br&gt;RBAC:           ClusterRole required — allows Kube-VIP to create/update lease objects&lt;br&gt;Config path:    /etc/kube-vip/config.yaml&lt;br&gt;Key env vars:   vip_address · vip_interface (NIC1 name) · vip_leasename&lt;br&gt;Install:        kubectl apply -f kube-vip-rbac.yaml then kubectl apply -f kube-vip-ds.yaml&lt;br&gt;Namespace:      kube-system — runs as a privileged DaemonSet pod&lt;/font&gt;" vertex="1">
          <mxGeometry height="118" width="848" x="26" y="810" as="geometry" />
        </mxCell>
        <mxCell id="why-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f7f0;strokeColor=#0078d4;strokeWidth=2;" value="" vertex="1">
          <mxGeometry height="158" width="860" x="900" y="776" as="geometry" />
        </mxCell>
        <mxCell id="why-hdr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#0078d4;fontSize=12;fontStyle=1;align=left;" value="Why Kube-VIP — Not MetalLB" vertex="1">
          <mxGeometry height="30" width="860" x="900" y="776" as="geometry" />
        </mxCell>
        <mxCell id="why-content" parent="1" style="text;html=1;fontSize=11;align=left;fillColor=none;strokeColor=none;verticalAlign=top;whiteSpace=wrap;" value="No BGP required — OT factory floor switches do not support BGP. Kube-VIP L2 ARP works on any standard L2 switch with no configuration needed on the switch side.&#xa;&#xa;Handles K3s API server VIP natively — MetalLB only handles Service type LoadBalancer. It cannot manage the K3s API server VIP. Kube-VIP handles both the API VIP and service VIPs in a single DaemonSet.&#xa;&#xa;Simpler operations — single DaemonSet to manage. MetalLB requires a separate controller and speaker components with additional configuration overhead.&#xa;&#xa;K3s recommended — Kube-VIP is the documented and recommended approach for K3s embedded etcd HA clusters. MetalLB requires additional integration steps." vertex="1">
          <mxGeometry height="118" width="848" x="906" y="810" as="geometry" />
        </mxCell>
        <mxCell id="ann1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;" value="Kube-VIP uses Gratuitous ARP (GARP) to announce VIPs. GARP is an unsolicited ARP reply that tells all devices on the subnet to update their ARP cache. No RARP, no BGP, no routing protocol." vertex="1">
          <mxGeometry height="30" width="860" x="20" y="946" as="geometry" />
        </mxCell>
        <mxCell id="ann2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;" value="ARP suppression must be disabled on the OT factory floor switch for Kube-VIP to work. If ARP suppression is enabled, GARP announcements are dropped and VIP failover will not function." vertex="1">
          <mxGeometry height="30" width="860" x="900" y="946" as="geometry" />
        </mxCell>
        <mxCell id="ann3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;" value="Kube-VIP leader election uses a Kubernetes Lease object — not etcd Raft. If etcd loses quorum, Kube-VIP leader election also halts because it cannot write the lease. VIP and etcd failures compound." vertex="1">
          <mxGeometry height="30" width="1740" x="20" y="982" as="geometry" />
        </mxCell>
        <mxCell id="MDwNy3AqHSFTtqIG4L4U-3" parent="1" style="aspect=fixed;sketch=0;html=1;dashed=0;whitespace=wrap;verticalLabelPosition=bottom;verticalAlign=top;fillColor=#2875E2;strokeColor=#ffffff;points=[[0.005,0.63,0],[0.1,0.2,0],[0.9,0.2,0],[0.5,0,0],[0.995,0.63,0],[0.72,0.99,0],[0.5,1,0],[0.28,0.99,0]];shape=mxgraph.kubernetes.icon2;kubernetesLabel=1;prIcon=node" value="" vertex="1">
          <mxGeometry height="45.12" width="47" x="983" y="325.88" as="geometry" />
        </mxCell>
        <mxCell id="MDwNy3AqHSFTtqIG4L4U-12" parent="1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" value="" vertex="1">
          <mxGeometry height="75.92" width="73.43" x="1993" y="564.27" as="geometry" />
        </mxCell>
        <mxCell id="MDwNy3AqHSFTtqIG4L4U-13" parent="1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" value="" vertex="1">
          <mxGeometry height="55.25" width="53.43" x="981" y="279" as="geometry" />
        </mxCell>
        <mxCell id="MDwNy3AqHSFTtqIG4L4U-14" parent="1" style="aspect=fixed;sketch=0;html=1;dashed=0;whitespace=wrap;verticalLabelPosition=bottom;verticalAlign=top;fillColor=#2875E2;strokeColor=#ffffff;points=[[0.005,0.63,0],[0.1,0.2,0],[0.9,0.2,0],[0.5,0,0],[0.995,0.63,0],[0.72,0.99,0],[0.5,1,0],[0.28,0.99,0]];shape=mxgraph.kubernetes.icon2;kubernetesLabel=1;prIcon=node" value="" vertex="1">
          <mxGeometry height="45.12" width="47" x="632.57" y="325.88" as="geometry" />
        </mxCell>
        <mxCell id="MDwNy3AqHSFTtqIG4L4U-15" parent="1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" value="" vertex="1">
          <mxGeometry height="52.74" width="51" x="631" y="280" as="geometry" />
        </mxCell>
        <mxCell id="MDwNy3AqHSFTtqIG4L4U-16" parent="1" style="aspect=fixed;sketch=0;html=1;dashed=0;whitespace=wrap;verticalLabelPosition=bottom;verticalAlign=top;fillColor=#2875E2;strokeColor=#ffffff;points=[[0.005,0.63,0],[0.1,0.2,0],[0.9,0.2,0],[0.5,0,0],[0.995,0.63,0],[0.72,0.99,0],[0.5,1,0],[0.28,0.99,0]];shape=mxgraph.kubernetes.icon2;kubernetesLabel=1;prIcon=node" value="" vertex="1">
          <mxGeometry height="45.12" width="47" x="282.57" y="325.38" as="geometry" />
        </mxCell>
        <mxCell id="MDwNy3AqHSFTtqIG4L4U-17" parent="1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" value="" vertex="1">
          <mxGeometry height="52.74" width="51" x="283" y="279.5" as="geometry" />
        </mxCell>
        <mxCell id="nX5p_18h_5iwhp2iB9t8-2" parent="1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" value="" vertex="1">
          <mxGeometry height="53.69" width="61" x="575" y="-23.85" as="geometry" />
        </mxCell>
      </root>
