        <mxCell id="fl-4-lbl" connectable="0" parent="fl-4" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;fontSize=10;fontColor=#82b366;fontStyle=1;" value="ALLOW  TCP :9090" vertex="1">
