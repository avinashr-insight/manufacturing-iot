            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="rel2-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f7f0;strokeColor=#0078d4;strokeWidth=2;" value="" vertex="1">
          <mxGeometry height="210" width="860" x="370" y="820" as="geometry" />
        </mxCell>
        <mxCell id="rel2-hdr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#0078d4;fontSize=12;fontStyle=1;align=left;" value="&amp;nbsp;Hubble and Cilium Relationship — Why Zero Overhead" vertex="1">
          <mxGeometry height="30" width="860" x="370" y="820" as="geometry" />
        </mxCell>
        <mxCell id="rel2-content" parent="1" style="text;html=1;fontSize=11;align=left;fillColor=none;strokeColor=none;verticalAlign=top;whiteSpace=wrap;" value="Traditional observability (e.g. tcpdump · Wireshark) works by duplicating packets — every packet is copied and sent to a monitoring process. At 250M transactions per week this is prohibitively expensive.&#xa;&#xa;Hubble works differently. Cilium is already processing every packet in eBPF to make routing and policy decisions. As part of that eBPF processing, Cilium writes a compact flow record to a perf ring buffer in kernel memory. Hubble Observer reads from that ring buffer. No packet duplication. No additional processing. The flow record is a side effect of work already done.&#xa;&#xa;The result: complete visibility into every flow across all namespaces, all pods, all 3 nodes — at zero additional cost to packet throughput or latency. This is why Hubble was a key selection criterion alongside the NetworkPolicy and latency capabilities." vertex="1">
          <mxGeometry height="170" width="848" x="376" y="854" as="geometry" />
        </mxCell>
        <mxCell id="ann1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;" value="Hubble Relay must be running for cluster-wide flow visibility. If Relay is down, only flows on the local node where the CLI is executed are visible — not the full cluster picture." vertex="1">
          <mxGeometry height="30" width="1760" x="26" y="1060" as="geometry" />
        </mxCell>
        <mxCell id="ann2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;" value="Hubble UI has no external ingress by default — access is via kubectl port-forward through the Secure Link / VDI path only. Do not expose Hubble UI externally." vertex="1">
          <mxGeometry height="30" width="1760" x="26" y="1100" as="geometry" />
        </mxCell>
        <mxCell id="ann3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#0078d4;fontSize=11;align=left;" value="Hubble does not replace Azure Monitor or Grafana. Hubble is for real-time network flow visibility at pod and namespace level. Azure Monitor is for cluster-wide metrics, logs, and alerting. Both are required." vertex="1">
          <mxGeometry height="30" width="1760" x="26" y="1140" as="geometry" />
        </mxCell>
        <mxCell id="MpDNs6NBignOMtkeWVBl-1" parent="1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" value="" vertex="1">
          <mxGeometry height="50.97" width="70" x="480" y="280" as="geometry" />
