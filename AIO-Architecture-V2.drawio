        <mxCell id="fl-5" edge="1" parent="1" source="pod-alt-core" style="endArrow=block;endFill=1;html=1;strokeColor=#b85450;strokeWidth=2;dashed=1;edgeStyle=orthogonalEdgeStyle;" target="pod-edgedb">
          <mxGeometry relative="1" as="geometry">
