  <diagram name="etcd-HA" id="BVF96nmLpiukgOtPYzSn">
    <mxGraphModel dx="2524" dy="1930" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;fontSize=18;fontStyle=1;align=left;fillColor=none;strokeColor=none;" value="&lt;font style=&quot;font-size: 24px;&quot;&gt;etcd High Availability and Raft Consensus · AIO Edge Cluster&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="900" x="620" y="-10" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;align=left;" value="Embedded etcd runs on all 3 K3s nodes. There is no external etcd cluster. Raft consensus requires a majority (2 of 3) for all writes. Loss of 2 nodes simultaneously halts the cluster." vertex="1">
          <mxGeometry height="34" width="1760" x="20" y="50" as="geometry" />
        </mxCell>
        <mxCell id="m1-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#82b366;strokeWidth=3;fontSize=13;" value="" vertex="1">
          <mxGeometry height="250" width="560" x="20" y="110" as="geometry" />
        </mxCell>
        <mxCell id="m1-hdr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#82b366;strokeColor=#6c9c57;fontColor=#ffffff;fontSize=13;fontStyle=1;align=center;" value="etcd Member 1 — K3s Node 1" vertex="1">
          <mxGeometry height="38" width="560" x="20" y="102" as="geometry" />
        </mxCell>
        <mxCell id="m1-role" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;align=center;" value="LEADER — accepts all writes · sends AppendEntries · commits on majority" vertex="1">
          <mxGeometry height="24" width="560" x="20" y="140" as="geometry" />
        </mxCell>
        <mxCell id="m1-content" parent="1" style="text;html=1;fontSize=13;align=left;fillColor=none;strokeColor=none;verticalAlign=top;" value="&lt;ul&gt;&lt;li&gt;Accepts all write requests from K3s API Server via :2379&lt;/li&gt;&lt;li&gt;Appends each entry to local WAL before replication begins&lt;/li&gt;&lt;li&gt;Sends AppendEntries RPC to all Followers via :2380 on every write&lt;/li&gt;&lt;li&gt;Sends periodic heartbeats (100ms interval) to suppress Follower elections&lt;/li&gt;&lt;li&gt;Commits entry after majority acknowledgment received (2 of 3 nodes)&lt;/li&gt;&lt;li&gt;Responds to K3s API Server only after commit is confirmed&lt;/li&gt;&lt;li&gt;Raft Term: N  (increments on each new election)&lt;/li&gt;&lt;li&gt;Ports: :2379 TCP client API  ·  :2380 TCP peer Raft&lt;/li&gt;&lt;li&gt;WAL: /var/lib/rancher/k3s/server/db/etcd/&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="200" width="450" x="90" y="170" as="geometry" />
        </mxCell>
        <mxCell id="m2-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#0078d4;strokeWidth=3;fontSize=13;" value="" vertex="1">
          <mxGeometry height="250" width="560" x="600" y="110" as="geometry" />
        </mxCell>
        <mxCell id="m2-hdr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0078d4;strokeColor=#0078d4;fontColor=#ffffff;fontSize=13;fontStyle=1;align=center;" value="etcd Member 2 — K3s Node 2" vertex="1">
          <mxGeometry height="38" width="560" x="600" y="102" as="geometry" />
        </mxCell>
        <mxCell id="m2-role" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;align=center;" value="FOLLOWER — replicates from Leader · votes in elections · ready to become Candidate" vertex="1">
          <mxGeometry height="24" width="560" x="600" y="140" as="geometry" />
        </mxCell>
        <mxCell id="m2-content" parent="1" style="text;html=1;fontSize=13;align=left;fillColor=none;strokeColor=none;verticalAlign=top;" value="&lt;ul&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Receives AppendEntries RPC from Leader — appends entry to local WAL&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Sends acknowledgment to Leader once entry is safely written to disk&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Redirects any direct client writes to the current Leader&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Monitors heartbeat timer (150-300ms randomised election timeout)&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Transitions to Candidate if no heartbeat received within timeout&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Votes in elections — grants vote to candidate with higher Term&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Will become LEADER if Node 1 fails and wins election&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Ports: :2379 TCP client API  ·  :2380 TCP peer Raft&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;WAL: /var/lib/rancher/k3s/server/db/etcd/&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="180" width="467" x="646.5" y="170" as="geometry" />
        </mxCell>
        <mxCell id="m3-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#0078d4;strokeWidth=3;fontSize=13;" value="" vertex="1">
          <mxGeometry height="250" width="580" x="1180" y="110" as="geometry" />
        </mxCell>
        <mxCell id="m3-hdr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0078d4;strokeColor=#0078d4;fontColor=#ffffff;fontSize=13;fontStyle=1;align=center;" value="etcd Member 3 — K3s Node 3" vertex="1">
          <mxGeometry height="38" width="580" x="1180" y="102" as="geometry" />
        </mxCell>
        <mxCell id="m3-role" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;align=center;" value="FOLLOWER — replicates from Leader · votes in elections · last-resort Candidate" vertex="1">
          <mxGeometry height="24" width="580" x="1182" y="140" as="geometry" />
        </mxCell>
        <mxCell id="m3-content" parent="1" style="text;html=1;fontSize=13;align=left;fillColor=none;strokeColor=none;verticalAlign=top;" value="&lt;ul&gt;&lt;li&gt;Receives AppendEntries RPC from Leader — appends entry to local WAL&lt;/li&gt;&lt;li&gt;Sends acknowledgment to Leader once entry is safely written to disk&lt;/li&gt;&lt;li&gt;Redirects any direct client writes to the current Leader&lt;/li&gt;&lt;li&gt;Monitors heartbeat timer (150-300ms randomised election timeout)&lt;/li&gt;&lt;li&gt;Transitions to Candidate if no heartbeat received within timeout&lt;/li&gt;&lt;li&gt;Votes in elections — grants vote to candidate with higher Term&lt;/li&gt;&lt;li&gt;Last-resort Leader — becomes LEADER only if both Node 1 and Node 2 fail&lt;/li&gt;&lt;li&gt;Ports: :2379 TCP client API  ·  :2380 TCP peer Raft&lt;/li&gt;&lt;li&gt;WAL: /var/lib/rancher/k3s/server/db/etcd/&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="188" width="504" x="1218" y="170" as="geometry" />
        </mxCell>
        <mxCell id="arr-m1-m2" edge="1" parent="1" style="endArrow=block;startArrow=block;endFill=1;startFill=1;html=1;strokeColor=#82b366;strokeWidth=2;fontSize=13;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="580" y="234" as="sourcePoint" />
            <mxPoint x="600" y="234" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="arr-m1-m2-lbl" connectable="0" parent="arr-m1-m2" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;fontSize=13;fontColor=#82b366;fontStyle=1;" value="AppendEntries + Heartbeat&#xa;:2380 Raft peer" vertex="1">
          <mxGeometry relative="0.5" as="geometry">
            <mxPoint y="-24" as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="arr-m2-m3" edge="1" parent="1" style="endArrow=block;startArrow=block;endFill=1;startFill=1;html=1;strokeColor=#0078d4;strokeWidth=2;fontSize=13;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1160" y="230" as="sourcePoint" />
            <mxPoint x="1180" y="230" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="arr-m2-m3-lbl" connectable="0" parent="arr-m2-m3" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;fontSize=13;fontColor=#0078d4;fontStyle=1;" value="AppendEntries + Heartbeat&#xa;:2380 Raft peer" vertex="1">
          <mxGeometry relative="0.5" as="geometry">
            <mxPoint y="-22" as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="arr-m1-m3" edge="1" parent="1" source="m1-box" style="endArrow=block;startArrow=block;endFill=1;startFill=1;html=1;strokeColor=#9673a6;strokeWidth=1;dashed=1;edgeStyle=orthogonalEdgeStyle;fontSize=13;" target="m3-box">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="300" y="400" />
              <mxPoint x="1470" y="400" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="arr-m1-m3-lbl" connectable="0" parent="arr-m1-m3" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;fontSize=13;fontColor=#9673a6;fontStyle=1;" value="&lt;font&gt;RequestVote RPC — direct peer communication (all nodes communicate with all nodes)&lt;/font&gt;" vertex="1">
          <mxGeometry relative="0.5" as="geometry">
            <mxPoint x="-4" y="-16" as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="wf-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f7f0;strokeColor=#82b366;strokeWidth=2;fontSize=13;" value="" vertex="1">
          <mxGeometry height="260" width="860" x="20" y="432" as="geometry" />
        </mxCell>
        <mxCell id="wf-hdr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;align=left;" value="Write Flow — How a K3s API Write Reaches etcd" vertex="1">
          <mxGeometry height="30" width="860" x="20" y="432" as="geometry" />
        </mxCell>
        <mxCell id="wf-content" parent="1" style="text;html=1;fontSize=13;align=left;fillColor=none;strokeColor=none;verticalAlign=top;" value="&lt;ul&gt;&lt;li&gt;Step 1    kubectl apply or resource creation hits K3s API Server&lt;/li&gt;&lt;li&gt;Step 2    K3s API Server sends write to etcd Leader via :2379 (client API)&lt;/li&gt;&lt;li&gt;Step 3    Leader appends entry to local WAL — marked as UNCOMMITTED&lt;/li&gt;&lt;li&gt;Step 4    Leader sends AppendEntries RPC to Member 2 and Member 3 via :2380&lt;/li&gt;&lt;li&gt;Step 5    Member 2 appends to local WAL — sends acknowledgment to Leader&lt;/li&gt;&lt;li&gt;Step 6    Leader receives 2 of 3 acknowledgments — MAJORITY REACHED&lt;/li&gt;&lt;li&gt;Step 7    Leader marks entry COMMITTED — applies to state machine&lt;/li&gt;&lt;li&gt;Step 8    Leader responds OK to K3s API Server — write confirmed to client&lt;/li&gt;&lt;li&gt;Step 9    Member 3 acknowledgment arrives — applied asynchronously (does not block)&lt;/li&gt;&lt;/ul&gt;&lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Leader does NOT wait for all 3 nodes — only majority (2 of 3) is required&lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Reads by default go to Leader for linearizability (strong consistency guarantee)" vertex="1">
          <mxGeometry height="220" width="848" x="26" y="466" as="geometry" />
        </mxCell>
        <mxCell id="le-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f7f0;strokeColor=#9673a6;strokeWidth=2;fontSize=13;" value="" vertex="1">
          <mxGeometry height="260" width="860" x="900" y="432" as="geometry" />
        </mxCell>
        <mxCell id="le-hdr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;align=left;" value="&amp;nbsp; &amp;nbsp;Leader Election — What Happens When the Leader Fails" vertex="1">
          <mxGeometry height="30" width="860" x="900" y="432" as="geometry" />
        </mxCell>
        <mxCell id="le-content" parent="1" style="text;html=1;fontSize=13;align=left;fillColor=none;strokeColor=none;verticalAlign=top;" value="Trigger    Follower receives no heartbeat from Leader for 150-300ms (randomised per node)&lt;br&gt;&lt;br&gt;&lt;ul&gt;&lt;li&gt;Step 1    Follower transitions to CANDIDATE state&lt;/li&gt;&lt;li&gt;Step 2    Candidate increments its current Raft Term by 1&lt;/li&gt;&lt;li&gt;Step 3    Candidate votes for itself&lt;/li&gt;&lt;li&gt;Step 4    Candidate sends RequestVote RPC to all peers via :2380&lt;/li&gt;&lt;li&gt;Step 5    Peer grants vote IF: candidate Term is higher AND candidate log is up to date&lt;/li&gt;&lt;li&gt;Step 6    First candidate to receive 2 of 3 votes becomes the new LEADER&lt;/li&gt;&lt;li&gt;Step 7    New Leader immediately sends heartbeats to all peers to reset timers&lt;/li&gt;&lt;li&gt;Step 8    Old Leader (if it recovers) sees higher Term — automatically reverts to Follower&lt;/li&gt;&lt;/ul&gt;Randomised timeout prevents split votes — nodes start elections at different times&lt;br&gt;Election typically completes in 300-600ms — independent of Kube-VIP ARP failover" vertex="1">
          <mxGeometry height="204" width="844" x="910" y="466" as="geometry" />
        </mxCell>
        <mxCell id="qs-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f7f0;strokeColor=#b85450;strokeWidth=2;fontSize=13;" value="" vertex="1">
          <mxGeometry height="210" width="860" x="20" y="710" as="geometry" />
        </mxCell>
        <mxCell id="qs-hdr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;align=left;" value="Quorum Scenarios — What Survives Node Loss" vertex="1">
          <mxGeometry height="30" width="860" x="20" y="710" as="geometry" />
        </mxCell>
        <mxCell id="qs-3-badge" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" value="3 of 3 alive" vertex="1">
          <mxGeometry height="28" width="120" x="26" y="748" as="geometry" />
        </mxCell>
        <mxCell id="qs-3-txt" parent="1" style="text;html=1;fontSize=13;align=left;fillColor=none;strokeColor=none;" value="Full quorum — all writes proceed normally — Leader replicates to both Followers" vertex="1">
          <mxGeometry height="28" width="720" x="154" y="748" as="geometry" />
        </mxCell>
        <mxCell id="qs-2-badge" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1;" value="2 of 3 alive" vertex="1">
          <mxGeometry height="28" width="120" x="26" y="782" as="geometry" />
        </mxCell>
        <mxCell id="qs-2-txt" parent="1" style="text;html=1;fontSize=13;align=left;fillColor=none;strokeColor=none;" value="Quorum maintained — 1 node loss tolerated — cluster continues — new election if Leader was lost" vertex="1">
          <mxGeometry height="28" width="720" x="154" y="782" as="geometry" />
        </mxCell>
        <mxCell id="qs-1-badge" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;" value="1 of 3 alive" vertex="1">
          <mxGeometry height="28" width="120" x="26" y="816" as="geometry" />
        </mxCell>
        <mxCell id="qs-1-txt" parent="1" style="text;html=1;fontSize=13;fontStyle=1;align=left;fillColor=none;strokeColor=none;" value="QUORUM LOST — no majority possible — reads and writes halt — K3s API unavailable — lines stop" vertex="1">
          <mxGeometry height="28" width="720" x="154" y="816" as="geometry" />
        </mxCell>
        <mxCell id="qs-0-badge" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;" value="0 of 3 alive" vertex="1">
          <mxGeometry height="28" width="120" x="26" y="850" as="geometry" />
        </mxCell>
        <mxCell id="qs-0-txt" parent="1" style="text;html=1;fontSize=13;align=left;fillColor=none;strokeColor=none;" value="Complete outage — restore from etcd snapshot backup or perform full cluster rebuild" vertex="1">
          <mxGeometry height="28" width="720" x="154" y="850" as="geometry" />
        </mxCell>
        <mxCell id="qs-note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;align=left;" value="2 simultaneous node failures = cluster unavailable regardless of Kube-VIP VIP failover — these are independent systems" vertex="1">
          <mxGeometry height="26" width="838" x="32" y="884" as="geometry" />
        </mxCell>
        <mxCell id="wal-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f7f0;strokeColor=#9673a6;strokeWidth=2;fontSize=13;" value="" vertex="1">
          <mxGeometry height="228" width="860" x="900" y="712" as="geometry" />
        </mxCell>
        <mxCell id="wal-hdr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;align=left;" value="WAL · Snapshots · What etcd Stores" vertex="1">
          <mxGeometry height="30" width="860" x="900" y="712" as="geometry" />
        </mxCell>
        <mxCell id="wal-left" parent="1" style="text;html=1;fontSize=13;align=left;fillColor=none;strokeColor=none;verticalAlign=top;" value="WAL — Write-Ahead Log&#xa;Sequential append-only log of every state change&#xa;Entry written to WAL before applied to state machine&#xa;Path: /var/lib/rancher/k3s/server/db/etcd/&#xa;Enables crash recovery by replaying from last good state&#xa;&#xa;Snapshots&#xa;Taken every 100 log entries (K3s embedded etcd default)&#xa;Serialised dump of the complete state machine at that point&#xa;Compacts the WAL — older entries pruned after snapshot&#xa;Recovery: load latest snapshot then replay WAL since snapshot" vertex="1">
          <mxGeometry height="158" width="400" x="906" y="746" as="geometry" />
        </mxCell>
        <mxCell id="wal-right-bg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;" value="" vertex="1">
          <mxGeometry height="160" width="444" x="1310" y="750" as="geometry" />
        </mxCell>
        <mxCell id="wal-right-lbl" parent="1" style="text;html=1;fontSize=13;fontStyle=1;align=left;fillColor=none;strokeColor=none;" value="All cluster state is stored in etcd" vertex="1">
          <mxGeometry height="20" width="426" x="1328" y="748.5" as="geometry" />
        </mxCell>
        <mxCell id="wal-right-d" parent="1" style="text;html=1;fontSize=13;align=left;fillColor=none;strokeColor=none;verticalAlign=top;" value="Pod specs · StatefulSets · Deployments&lt;br&gt;Services · Endpoints · Ingress rules&lt;br&gt;ConfigMaps · Secrets (base64 encoded)&lt;br&gt;Namespaces · RBAC roles and bindings&lt;br&gt;Node registrations and node status&lt;br&gt;CRDs: Flux GitRepository · Kustomization&lt;br&gt;AIO broker config · Cilium NetworkPolicies&lt;br&gt;Loss of etcd without a backup requires a full cluster rebuild" vertex="1">
          <mxGeometry height="130" width="370" x="1340" y="774" as="geometry" />
        </mxCell>
        <mxCell id="ann1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;align=left;" value="Raft requires a majority (quorum) for every write. With 3 nodes, majority = 2. This means 1 node failure is tolerated but 2 simultaneous failures halt the cluster entirely." vertex="1">
          <mxGeometry height="30" width="860" x="14" y="980" as="geometry" />
        </mxCell>
        <mxCell id="ann2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;" value="etcd Leader election (300-600ms) and Kube-VIP ARP failover (~1-2s) are completely independent. A new etcd Leader can be elected before Kube-VIP has even finished moving the VIP." vertex="1">
          <mxGeometry height="30" width="860" x="910" y="980" as="geometry" />
        </mxCell>
        <mxCell id="ann3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;" value="All 3 nodes store a full copy of etcd state. A node that rejoins after failure replays the WAL from the current Leader to catch up automatically — no manual intervention required." vertex="1">
          <mxGeometry height="30" width="860" x="14" y="1020" as="geometry" />
        </mxCell>
        <mxCell id="ann4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;" value="etcd backup is required for production. K3s does not automatically copy snapshots off-node. Snapshots must be scheduled to ADLS or another durable store as part of the Day-2 operations runbook." vertex="1">
          <mxGeometry height="30" width="860" x="910" y="1020" as="geometry" />
        </mxCell>
        <mxCell id="D5EP33qowKsbXpQoQviO-1" parent="1" style="aspect=fixed;sketch=0;html=1;dashed=0;whitespace=wrap;verticalLabelPosition=bottom;verticalAlign=top;fillColor=#2875E2;strokeColor=#ffffff;points=[[0.005,0.63,0],[0.1,0.2,0],[0.9,0.2,0],[0.5,0,0],[0.995,0.63,0],[0.72,0.99,0],[0.5,1,0],[0.28,0.99,0]];shape=mxgraph.kubernetes.icon2;prIcon=etcd;fontSize=13;" value="" vertex="1">
          <mxGeometry height="48" width="50" x="510" y="290" as="geometry" />
        </mxCell>
        <mxCell id="D5EP33qowKsbXpQoQviO-2" parent="1" style="aspect=fixed;sketch=0;html=1;dashed=0;whitespace=wrap;verticalLabelPosition=bottom;verticalAlign=top;fillColor=#2875E2;strokeColor=#ffffff;points=[[0.005,0.63,0],[0.1,0.2,0],[0.9,0.2,0],[0.5,0,0],[0.995,0.63,0],[0.72,0.99,0],[0.5,1,0],[0.28,0.99,0]];shape=mxgraph.kubernetes.icon2;prIcon=etcd;fontSize=13;" value="" vertex="1">
          <mxGeometry height="57.6" width="60" x="1080" y="280.4" as="geometry" />
        </mxCell>
        <mxCell id="D5EP33qowKsbXpQoQviO-3" parent="1" style="aspect=fixed;sketch=0;html=1;dashed=0;whitespace=wrap;verticalLabelPosition=bottom;verticalAlign=top;fillColor=#2875E2;strokeColor=#ffffff;points=[[0.005,0.63,0],[0.1,0.2,0],[0.9,0.2,0],[0.5,0,0],[0.995,0.63,0],[0.72,0.99,0],[0.5,1,0],[0.28,0.99,0]];shape=mxgraph.kubernetes.icon2;prIcon=etcd;fontSize=13;" value="" vertex="1">
          <mxGeometry height="57.6" width="60" x="1680" y="280.4" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="Kube-VIP" id="nvzyS8wA69grd2Yj5o0c">
    <mxGraphModel dx="1834" dy="1264" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;fontSize=18;fontStyle=1;align=left;fillColor=none;strokeColor=none;" value="&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Kube-VIP Deep Dive · L2 ARP Mode · DaemonSet · VIP Failover" vertex="1">
          <mxGeometry height="30" width="900" x="170" y="-12" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;" value="Kube-VIP runs as a DaemonSet on all 3 nodes. One node is ACTIVE (holds VIPs via ARP). Two are STANDBY (monitor and take over on failure). VIP failover is ~1-2s. Pod rescheduling is ~40-60s. These are independent events." vertex="1">
          <mxGeometry height="34" width="1760" x="20" y="50" as="geometry" />
        </mxCell>
        <mxCell id="nodeip-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f7f0;strokeColor=#b4b2a9;strokeWidth=2;" value="" vertex="1">
          <mxGeometry height="80" width="1760" x="20" y="94" as="geometry" />
        </mxCell>
        <mxCell id="nodeip-title" parent="1" style="text;html=1;fontSize=13;fontStyle=1;align=center;fillColor=none;strokeColor=none;" value="Node IP vs VIP — The Critical Distinction" vertex="1">
          <mxGeometry height="22" width="1760" x="20" y="96" as="geometry" />
        </mxCell>
        <mxCell id="nodeip-left" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;" value="Node IP — Static · Permanent · Bound to NIC · Never Moves&#xa;Assigned at OS level to NIC1 (OT) and NIC2 (DC VLAN). Used for: SSH admin access · etcd peer communication (:2380) · Cilium VXLAN overlay (:8472) · kubelet (:10250). Even if the node is STANDBY for Kube-VIP, its node IPs always exist and are always reachable." vertex="1">
          <mxGeometry height="48" width="860" x="26" y="120" as="geometry" />
        </mxCell>
        <mxCell id="nodeip-right" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;" value="VIP — Floating · Managed by Kube-VIP · Moves on Failure · External-Facing&lt;br&gt;Not bound to any NIC permanently. Announced via ARP by whichever node is currently ACTIVE. Used by: kubectl · Azure Arc · Ignition gateway (MQTT) · cluster API ingress. Clients always connect to the VIP — they never need to know which physical node holds it." vertex="1">
          <mxGeometry height="48" width="880" x="894" y="120" as="geometry" />
        </mxCell>
        <mxCell id="ns-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f7f0;strokeColor=#82b366;strokeWidth=2;" value="" vertex="1">
          <mxGeometry height="264" width="1060" x="20" y="186" as="geometry" />
        </mxCell>
        <mxCell id="ns-hdr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;align=left;" value="Normal Operating State — Node 1 is ACTIVE VIP Holder" vertex="1">
          <mxGeometry height="30" width="1060" x="20" y="186" as="geometry" />
        </mxCell>
        <mxCell id="vip-block" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#82b366;strokeColor=#6c9c57;fontColor=#ffffff;fontSize=11;fontStyle=1;align=center;" value="API VIP :6443   ·   MQTT VIP :8883   ·   HTTPS VIP :443   (all on OT /27 subnet)" vertex="1">
          <mxGeometry height="26" width="660" x="26" y="222" as="geometry" />
        </mxCell>
        <mxCell id="arr-vip-n1" edge="1" parent="1" style="endArrow=block;endFill=1;html=1;strokeColor=#82b366;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="356" y="248" as="sourcePoint" />
            <mxPoint x="176" y="260" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="ns-n1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#82b366;strokeWidth=3;" value="" vertex="1">
          <mxGeometry height="120" width="310" x="26" y="256" as="geometry" />
        </mxCell>
        <mxCell id="ns-n1-hdr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#82b366;strokeColor=#6c9c57;fontColor=#ffffff;fontSize=11;fontStyle=1;align=center;" value="Node 1 — K3s Node 1" vertex="1">
          <mxGeometry height="26" width="310" x="26" y="255" as="geometry" />
        </mxCell>
        <mxCell id="ns-n1-content" parent="1" style="text;html=1;fontSize=11;align=left;fillColor=none;strokeColor=none;verticalAlign=top;" value="Kube-VIP Speaker — ACTIVE&#xa;Owns all 3 VIPs via ARP&#xa;NIC1: 192.168.xx.10&#xa;Broadcasts GARP to announce VIPs" vertex="1">
          <mxGeometry height="86" width="298" x="32" y="285" as="geometry" />
        </mxCell>
        <mxCell id="ns-n2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#d6b656;strokeWidth=3;" value="" vertex="1">
          <mxGeometry height="120" width="310" x="376" y="256" as="geometry" />
        </mxCell>
        <mxCell id="ns-n2-hdr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;align=center;" value="Node 2 — K3s Node 2" vertex="1">
          <mxGeometry height="26" width="310" x="375" y="255" as="geometry" />
        </mxCell>
        <mxCell id="ns-n2-content" parent="1" style="text;html=1;fontSize=11;align=left;fillColor=none;strokeColor=none;verticalAlign=top;" value="Kube-VIP Speaker — STANDBY&#xa;No VIPs held currently&#xa;NIC1: 192.168.xx.11&#xa;Monitors ACTIVE — ready to claim VIPs" vertex="1">
          <mxGeometry height="86" width="298" x="382" y="285" as="geometry" />
        </mxCell>
        <mxCell id="ns-n3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#d6b656;strokeWidth=3;" value="" vertex="1">
          <mxGeometry height="120" width="310" x="726" y="256" as="geometry" />
        </mxCell>
        <mxCell id="ns-n3-hdr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;align=center;" value="Node 3 — K3s Node 3" vertex="1">
          <mxGeometry height="26" width="310" x="725" y="255" as="geometry" />
        </mxCell>
        <mxCell id="ns-n3-content" parent="1" style="text;html=1;fontSize=11;align=left;fillColor=none;strokeColor=none;verticalAlign=top;" value="Kube-VIP Speaker — STANDBY&#xa;No VIPs held currently&#xa;NIC1: 192.168.xx.12&#xa;Last-resort — claims VIPs if Node 1+2 fail" vertex="1">
          <mxGeometry height="86" width="298" x="732" y="285" as="geometry" />
        </mxCell>
        <mxCell id="ns-arp" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;align=left;" value="OT /27 Subnet — ARP Table on factory switch:   API VIP → Node 1 MAC   ·   MQTT VIP → Node 1 MAC   ·   HTTPS VIP → Node 1 MAC" vertex="1">
          <mxGeometry height="28" width="1048" x="26" y="386" as="geometry" />
        </mxCell>
        <mxCell id="ns-note" parent="1" style="text;html=1;fontSize=11;align=left;fillColor=none;strokeColor=none;fontStyle=2;" value="&amp;nbsp; (Ignition gateway · kubectl · Azure Arc) always connect to the VIP addresses — they never reference node IPs directly" vertex="1">
          <mxGeometry height="20" width="1048" x="26" y="418" as="geometry" />
        </mxCell>
        <mxCell id="vt-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f7f0;strokeColor=#82b366;strokeWidth=2;" value="" vertex="1">
          <mxGeometry height="264" width="680" x="1100" y="186" as="geometry" />
        </mxCell>
        <mxCell id="vt-hdr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;align=left;" value="VIP Reference Table" vertex="1">
          <mxGeometry height="30" width="680" x="1100" y="186" as="geometry" />
        </mxCell>
        <mxCell id="vt-api-lbl" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" value="K3s API VIP" vertex="1">
          <mxGeometry height="30" width="120" x="1106" y="230" as="geometry" />
        </mxCell>
        <mxCell id="vt-api-d" parent="1" style="text;html=1;fontSize=11;align=left;fillColor=none;strokeColor=none;" value="192.168.xx.xxx  :6443  TCP&#xa;kubectl · Azure Arc · admin kubeconfig&#xa;K3s API server — cluster management" vertex="1">
          <mxGeometry height="44" width="540" x="1234" y="216" as="geometry" />
        </mxCell>
        <mxCell id="vt-mqtt-lbl" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" value="MQTT VIP" vertex="1">
          <mxGeometry height="30" width="120" x="1106" y="285" as="geometry" />
        </mxCell>
        <mxCell id="vt-mqtt-d" parent="1" style="text;html=1;fontSize=11;align=left;fillColor=none;strokeColor=none;" value="192.168.xx.xxx  :8883  TCP (MQTT over TLS)&lt;br&gt;Ignition gateway MQTT publish · ALT services&lt;br&gt;AIO broker ingress — primary data path" vertex="1">
          <mxGeometry height="44" width="540" x="1234" y="271" as="geometry" />
        </mxCell>
        <mxCell id="vt-https-lbl" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;" value="HTTPS VIP" vertex="1">
