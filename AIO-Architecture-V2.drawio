        <mxCell id="AVhJbBLsYbVpbcTlqR0A-2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;align=left;" value="Node Failure Behaviour — What Happens to Storage" vertex="1">
