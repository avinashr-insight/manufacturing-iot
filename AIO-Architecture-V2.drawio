        </mxCell>
        <mxCell id="vt-https-d" parent="1" style="text;html=1;fontSize=11;align=left;fillColor=none;strokeColor=none;" value="192.168.xx.xxx  :443  TCP&#xa;Cluster API ingress · service endpoints&#xa;Internal HTTPS traffic to cluster services" vertex="1">
          <mxGeometry height="44" width="540" x="1234" y="327" as="geometry" />
