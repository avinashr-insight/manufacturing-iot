        <mxCell id="disk1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=11;align=center;" value="Node 1 Disk&#xa;/var/lib/rancher/k3s/&#xa;storage/edge-db-0" vertex="1">
          <mxGeometry height="60" width="225" x="1068" y="334" as="geometry" />
        </mxCell>
        <mxCell id="disk2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=11;align=center;" value="Node 2 Disk&#xa;/var/lib/rancher/k3s/&#xa;storage/edge-db-1" vertex="1">
          <mxGeometry height="57" width="224" x="1068" y="404" as="geometry" />
        </mxCell>
        <mxCell id="disk3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=11;align=center;" value="Node 3 Disk&#xa;/var/lib/rancher/k3s/&#xa;storage/edge-db-2" vertex="1">
          <mxGeometry height="57" width="224" x="1068" y="474" as="geometry" />
        </mxCell>
        <mxCell id="rwo-note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=2;align=left;" value="RWO = ReadWriteOnce — each PV is mounted by exactly one pod on one node at a time. The pod and its data are always co-located on the same node." vertex="1">
          <mxGeometry height="34" width="492" x="57" y="574" as="geometry" />
        </mxCell>
        <mxCell id="retain-note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=2;align=left;" value="reclaimPolicy: Retain — if a PVC is deleted, the PV and its data are NOT deleted. Data survives accidental PVC deletion. Manual cleanup required." vertex="1">
          <mxGeometry height="34" width="492" x="574" y="574" as="geometry" />
        </mxCell>
        <mxCell id="ss-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f7f0;strokeColor=#9673a6;strokeWidth=2;fontSize=13;" value="" vertex="1">
          <mxGeometry height="307" width="859" x="30" y="662" as="geometry" />
        </mxCell>
        <mxCell id="ss-hdr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;align=left;" value="StatefulSet Behaviour — Why StatefulSet and Not Deployment" vertex="1">
          <mxGeometry height="30" width="860" x="30" y="657" as="geometry" />
        </mxCell>
        <mxCell id="ss-content" parent="1" style="text;html=1;fontSize=13;align=left;fillColor=none;strokeColor=none;verticalAlign=top;whiteSpace=wrap;" value="A Deployment treats all pods as identical and interchangeable — any pod can run on any node. This is fine for stateless workloads but catastrophic for databases. If edge-db-0 is rescheduled to a different node, it loses its data.&#xa;&#xa;A StatefulSet gives each pod a stable identity and a stable storage binding:&#xa;&#xa;  edge-db-0  →  always bound to PVC data-edge-db-0  →  always on Node 1&#xa;  edge-db-1  →  always bound to PVC data-edge-db-1  →  always on Node 2&#xa;  edge-db-2  →  always bound to PVC data-edge-db-2  →  always on Node 3&#xa;&#xa;If edge-db-0 pod crashes — K3s restarts it on Node 1 and remounts the same PV.&#xa;Pod identity is preserved. Data is preserved. No data loss.&#xa;&#xa;Ordered startup — StatefulSet starts pods in order (0, 1, 2) and waits for each&#xa;to be Ready before starting the next. Critical for PostgreSQL primary/replica setup.&#xa;&#xa;Ordered shutdown — pods stop in reverse order (2, 1, 0). Primary is last to stop." vertex="1">
          <mxGeometry height="220" width="848" x="36" y="696" as="geometry" />
        </mxCell>
        <mxCell id="ret-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f7f0;strokeColor=#d6b656;strokeWidth=2;fontSize=13;" value="" vertex="1">
          <mxGeometry height="111" width="859" x="32" y="978" as="geometry" />
        </mxCell>
        <mxCell id="ret-hdr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1;align=left;" value="Data Retention — Edge-db is a Buffer, Not a System of Record" vertex="1">
          <mxGeometry height="30" width="860" x="32" y="978" as="geometry" />
        </mxCell>
        <mxCell id="ret-content" parent="1" style="text;html=1;fontSize=13;align=left;fillColor=none;strokeColor=none;verticalAlign=top;fontFamily=Courier New;" value="&lt;ul&gt;&lt;li&gt;&lt;font face=&quot;Helvetica&quot;&gt;Minimum retention:   8 hours  (client confirmed hard requirement)&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Helvetica&quot;&gt;Buffer retention:    72 hours  (AIO max — provides buffer for sync failures or connectivity gaps)&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Helvetica&quot;&gt;System of record:    ADLS Gen2  (bronze layer · 400 days hot · 50 years cold archive)&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Helvetica&quot;&gt;Sync path:           AIO dataflow → ADLS Gen2 via OT ExpressRoute → IDMZ → Azure&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="60" width="848" x="25" y="996" as="geometry" />
        </mxCell>
        <mxCell id="ann1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#0078d4;fontSize=12;align=left;" value="ACSA is an Arc extension — it must be registered and healthy before the edge-db StatefulSet is deployed. If ACSA is not running, PVC creation will hang in Pending state indefinitely." vertex="1">
          <mxGeometry height="40" width="865" x="926" y="978" as="geometry" />
        </mxCell>
        <mxCell id="ann2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;" value="Local disk storage means data does NOT replicate automatically across nodes at the storage layer. PostgreSQL replication handles data redundancy at the application layer across the 3 StatefulSet replicas." vertex="1">
          <mxGeometry height="35" width="864" x="926" y="1024" as="geometry" />
        </mxCell>
        <mxCell id="ann3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;align=left;" value="reclaimPolicy: Retain is critical for production. If set to Delete, a kubectl delete pvc accidentally wipes all edge data. Retain means data survives — manual cleanup is required before storage can be reused." vertex="1">
          <mxGeometry height="41" width="870" x="924" y="1120" as="geometry" />
        </mxCell>
        <mxCell id="ann4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;" value="WaitForFirstConsumer binding mode means the PV is not provisioned until a pod is scheduled. This ensures the PV is created on the same node as the pod — not on a random node before the pod is placed." vertex="1">
          <mxGeometry height="45" width="864" x="926" y="1067" as="geometry" />
        </mxCell>
        <mxCell id="ann5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;" value="Edge-db holds 8h minimum and up to 72h of data. If the ExpressRoute to Azure is down for more than 72h and the buffer fills, older records are overwritten. The ADLS sync path must be monitored and alerted." vertex="1">
          <mxGeometry height="45" width="872" x="922" y="1169" as="geometry" />
        </mxCell>
        <mxCell id="6jhJDdahwVrgmBPOoBom-1" parent="1" style="aspect=fixed;sketch=0;html=1;dashed=0;whitespace=wrap;verticalLabelPosition=bottom;verticalAlign=top;fillColor=#2875E2;strokeColor=#ffffff;points=[[0.005,0.63,0],[0.1,0.2,0],[0.9,0.2,0],[0.5,0,0],[0.995,0.63,0],[0.72,0.99,0],[0.5,1,0],[0.28,0.99,0]];shape=mxgraph.kubernetes.icon2;kubernetesLabel=1;prIcon=pvc" value="" vertex="1">
