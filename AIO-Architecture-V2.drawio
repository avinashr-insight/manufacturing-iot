            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="fl-5-lbl" connectable="0" parent="fl-5" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;fontSize=10;fontColor=#b85450;fontStyle=1;" value="DROP  TCP :5432  (NetworkPolicy — alt-system not allowed to reach edge-db directly)" vertex="1">
