  <diagram id="Pzp33Ns1bQY7iETBuF0m" name="ACSA">
    <mxGraphModel dx="2019" dy="1264" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;fontSize=18;fontStyle=1;align=left;fillColor=none;strokeColor=none;" value="ACSA and Storage Persistence · StorageClass · PVC · StatefulSet · Failure Behavior" vertex="1">
          <mxGeometry height="30" width="810" x="448" y="-76" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#0078d4;fontSize=12;align=left;" value="ACSA (Azure Container Storage enabled by Azure Arc) provides a StorageClass that provisions PersistentVolumes backed by local NVMe/SSD disk on each node. The PostgreSQL edge-db StatefulSet uses this StorageClass to maintain data persistence across pod restarts, rescheduling, and node failures." vertex="1">
          <mxGeometry height="34" width="1760" x="4" y="-37" as="geometry" />
        </mxCell>
        <mxCell id="acsa-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f7f0;strokeColor=#0078d4;strokeWidth=2;fontSize=13;" value="" vertex="1">
          <mxGeometry height="258" width="863" x="4" y="7" as="geometry" />
        </mxCell>
        <mxCell id="acsa-hdr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#0078d4;fontSize=13;fontStyle=1;align=left;" value="What is ACSA — Azure Container Storage enabled by Azure Arc" vertex="1">
          <mxGeometry height="30" width="860" x="4" y="7" as="geometry" />
        </mxCell>
        <mxCell id="acsa-content" parent="1" style="text;html=1;fontSize=13;align=left;fillColor=none;strokeColor=none;verticalAlign=top;whiteSpace=wrap;" value="ACSA is a Kubernetes storage operator deployed and managed by Azure Arc. It provides a StorageClass that abstracts local disk storage on bare-metal nodes into Kubernetes-native PersistentVolumes.&#xa;&#xa;Without ACSA — local disk storage on K3s nodes is unmanaged. Pods that use hostPath volumes are tightly coupled to a specific node and cannot be rescheduled to another node if the first fails.&#xa;&#xa;With ACSA — local disk is managed through the Kubernetes PVC/PV lifecycle. Pods declare a storage claim, ACSA provisions the volume, and the binding is tracked by the cluster. On pod reschedule, ACSA ensures the pod lands on the node where its data lives.&#xa;&#xa;Deployed as:    CRD + operator — managed by Azure Arc GitOps&#xa;StorageClass:   acstor-local (or configured name) · provisioner: disk.csi.azure.com&#xa;Backed by:      Local NVMe or SSD disk on each node · no network storage required&#xa;Arc dependency: ACSA operator must be registered as an Arc extension before use" vertex="1">
          <mxGeometry height="150" width="848" x="10" y="41" as="geometry" />
        </mxCell>
        <mxCell id="why-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f7f0;strokeColor=#82b366;strokeWidth=2;fontSize=13;" value="" vertex="1">
          <mxGeometry height="255" width="871" x="885" y="7" as="geometry" />
        </mxCell>
        <mxCell id="why-hdr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;align=left;" value="Why Local Disk — Not Network Storage" vertex="1">
          <mxGeometry height="30" width="860" x="884" y="7" as="geometry" />
        </mxCell>
        <mxCell id="why-content" parent="1" style="text;html=1;fontSize=13;align=left;fillColor=none;strokeColor=none;verticalAlign=top;whiteSpace=wrap;" value="Closed network — these clusters have no internet access and no connection to Azure managed storage services such as Azure Disk or Azure Files. All storage must be on-node.&#xa;&#xa;Latency SLA — the 200ms end-to-end latency SLA for permissive control (PLC to ALT to response) means storage I/O must be as fast as possible. Network storage adds variable latency on every read/write. Local NVMe/SSD is deterministic and fast.&#xa;&#xa;Edge-first design — edge-db is a buffer, not a system of record. It holds 8h of data minimum (72h buffer) before sync to ADLS Gen2. This is exactly the use case local disk is designed for — high throughput, low latency, bounded retention.&#xa;&#xa;No SAN/NAS available — the factory floor DC VLAN has no shared storage infrastructure. No iSCSI, no NFS, no Fibre Channel. Local disk is the only option available on-site." vertex="1">
          <mxGeometry height="150" width="848" x="890" y="41" as="geometry" />
        </mxCell>
        <mxCell id="pvc-outer" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f7f0;strokeColor=#9673a6;strokeWidth=2;" value="" vertex="1">
          <mxGeometry height="324" width="1762" x="20" y="294" as="geometry" />
        </mxCell>
        <mxCell id="pvc-hdr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;align=left;" value="PVC and PV Lifecycle — How Storage is Claimed and Bound" vertex="1">
          <mxGeometry height="37" width="1760" x="20" y="287" as="geometry" />
        </mxCell>
