        <mxCell id="fs-v3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=center;" value="Node 2 wins&#xa;Kube-VIP leader&#xa;election — highest&#xa;priority speaker" vertex="1">
