  </diagram>
  <diagram id="kfsZC_rvv9kPc-D93oN1" name="Cilium-Hubble">
    <mxGraphModel dx="1834" dy="864" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;fontSize=18;fontStyle=1;align=left;fillColor=none;strokeColor=none;" value="Hubble Observability · Flow Visibility · Cross-Namespace Debugging" vertex="1">
          <mxGeometry height="30" width="900" x="590" y="10" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#0078d4;fontSize=12;align=left;" value="Hubble is Cilium&#39;s built-in observability layer. It captures every network flow processed by eBPF across all nodes with zero additional overhead — no sidecar, no agent, no extra instrumentation. Critical for debugging the alt-system to azure-iot-operations MQTT traffic path." vertex="1">
          <mxGeometry height="34" width="1760" x="20" y="50" as="geometry" />
        </mxCell>
        <mxCell id="arch-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f7f0;strokeColor=#0078d4;strokeWidth=2;" value="" vertex="1">
          <mxGeometry height="260" width="1760" x="20" y="94" as="geometry" />
        </mxCell>
        <mxCell id="arch-hdr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#0078d4;fontSize=12;fontStyle=1;align=left;" value="Hubble Architecture — Three Components" vertex="1">
          <mxGeometry height="30" width="1760" x="20" y="94" as="geometry" />
        </mxCell>
        <mxCell id="obs-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#0078d4;strokeWidth=2;" value="" vertex="1">
          <mxGeometry height="216" width="540" x="26" y="130" as="geometry" />
        </mxCell>
        <mxCell id="obs-hdr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#0078d4;fontSize=11;fontStyle=1;align=center;" value="Hubble Observer (per node — DaemonSet)" vertex="1">
          <mxGeometry height="26" width="540" x="26" y="130" as="geometry" />
        </mxCell>
        <mxCell id="obs-content" parent="1" style="text;html=1;fontSize=11;align=left;fillColor=none;strokeColor=none;verticalAlign=top;" value="Runs as part of the Cilium Agent DaemonSet pod on every node&#xa;Reads flow events directly from eBPF perf ring buffer in kernel&#xa;Zero overhead — flows are already being processed by eBPF&#xa;No packet duplication or mirroring required&#xa;&#xa;Captures per flow:&#xa;  Source pod · namespace · IP · port&#xa;  Destination pod · namespace · IP · port&#xa;  Protocol · verdict (ALLOW / DROP / REDIRECT)&#xa;  HTTP method + path (if L7 policy applied)&#xa;  Timestamp · latency&#xa;&#xa;Exposes flows via gRPC on :4244 (local node only)" vertex="1">
          <mxGeometry height="180" width="528" x="32" y="160" as="geometry" />
        </mxCell>
        <mxCell id="arr-obs-rel" edge="1" parent="1" style="endArrow=block;endFill=1;html=1;strokeColor=#0078d4;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="566" y="240" as="sourcePoint" />
            <mxPoint x="620" y="240" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="arr-obs-rel-lbl" connectable="0" parent="arr-obs-rel" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;fontSize=10;fontColor=#0078d4;fontStyle=1;" value="gRPC :4244" vertex="1">
          <mxGeometry relative="0.5" as="geometry">
            <mxPoint y="-14" as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="rel-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#9673a6;strokeWidth=2;" value="" vertex="1">
          <mxGeometry height="216" width="540" x="626" y="130" as="geometry" />
        </mxCell>
        <mxCell id="rel-hdr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;align=center;" value="Hubble Relay (single Deployment — cluster-wide aggregator)" vertex="1">
          <mxGeometry height="26" width="540" x="626" y="130" as="geometry" />
        </mxCell>
        <mxCell id="rel-content" parent="1" style="text;html=1;fontSize=11;align=left;fillColor=none;strokeColor=none;verticalAlign=top;" value="Single pod running in kube-system namespace&#xa;Connects to Hubble Observer on every node via gRPC :4244&#xa;Aggregates flows from all 3 nodes into a single stream&#xa;Exposes unified gRPC API on :4245 for Hubble UI and CLI&#xa;&#xa;Without Relay — you can only see flows on the local node&#xa;With Relay — you see flows across the entire cluster&#xa;&#xa;Namespace: kube-system&#xa;Service: hubble-relay (ClusterIP)&#xa;Port: :4245 gRPC (consumed by Hubble UI and hubble CLI)&#xa;&#xa;Enabled via Helm: --set hubble.relay.enabled=true" vertex="1">
          <mxGeometry height="180" width="528" x="632" y="160" as="geometry" />
        </mxCell>
        <mxCell id="arr-rel-ui" edge="1" parent="1" style="endArrow=block;endFill=1;html=1;strokeColor=#9673a6;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry">
