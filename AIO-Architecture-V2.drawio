        <mxCell id="fs-v4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;" value="Node 2 broadcasts&#xa;Gratuitous ARP&#xa;(GARP) on OT&#xa;/27 subnet" vertex="1">
          <mxGeometry height="76" width="230" x="864" y="500" as="geometry" />
        </mxCell>
        <mxCell id="arr-fv4" edge="1" parent="1" style="endArrow=block;endFill=1;html=1;strokeColor=#82b366;strokeWidth=2;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="fs-v5">
          <mxGeometry relative="1" as="geometry">
