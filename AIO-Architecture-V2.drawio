        <mxCell id="ann1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;" value="All 3 nodes = K3s Server role — control plane AND workloads run on every node simultaneously. There is no dedicated master and no worker-only nodes." vertex="1">
          <mxGeometry height="30" width="805" x="5" y="1000" as="geometry" />
        </mxCell>
        <mxCell id="ann2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;" value="etcd quorum requires 2 of 3 members alive. Single node failure — cluster continues. Two simultaneous failures — quorum lost — K3s API halts — lines stop." vertex="1">
          <mxGeometry height="30" width="835" x="5" y="1040" as="geometry" />
        </mxCell>
        <mxCell id="ann3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;" value="Kube-VIP failover (~1-2s) and pod reschedule (~40-60s) are INDEPENDENT EVENTS. VIPs move fast via ARP re-election. Pods move slow via K3s scheduler. Do not conflate the two timelines." vertex="1">
          <mxGeometry height="30" width="1100" x="5" y="1080" as="geometry" />
        </mxCell>
        <mxCell id="ann4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;" value="Cilium MUST be installed AFTER K3s with --flannel-backend=none --disable-network-policy. Installing in wrong order requires full cluster teardown and reinstall." vertex="1">
          <mxGeometry height="30" width="730" x="5" y="960" as="geometry" />
        </mxCell>
