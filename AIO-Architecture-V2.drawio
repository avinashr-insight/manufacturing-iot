        <mxCell id="236" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=center;snapToPoint=0;" value="No additional client impact&#xa;VIP stable on Node 2&#xa;Partial ALT replica count&#xa;but requests still served" vertex="1">
          <mxGeometry height="110" width="280" x="700" y="1460" as="geometry" />
        </mxCell>
        <mxCell id="237" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=center;snapToPoint=0;" value="No client impact&#xa;New pods coming online&#xa;Load balanced across&#xa;Nodes 2+3" vertex="1">
          <mxGeometry height="110" width="280" x="980" y="1460" as="geometry" />
        </mxCell>
        <mxCell id="238" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=center;snapToPoint=0;" value="Full capacity restored&#xa;All services Running&#xa;200ms SLA maintained&#xa;No config change needed" vertex="1">
          <mxGeometry height="110" width="240" x="1260" y="1460" as="geometry" />
        </mxCell>
        <mxCell id="239" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;align=center;snapToPoint=0;" value="Fully recovered&#xa;Cluster operating normally&#xa;on 2 nodes until&#xa;Node 1 is restored" vertex="1">
          <mxGeometry height="110" width="270" x="1500" y="1460" as="geometry" />
        </mxCell>
        <mxCell id="240" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;snapToPoint=0;" value="edge-db-0 is the only component that does NOT fully recover within 60s. It remains PENDING until Node 1 disk is accessible. This is by design — ACSA RWO local disk cannot be remounted elsewhere. PostgreSQL continues with 2 replicas — no data loss." vertex="1">
          <mxGeometry height="28" width="1510" x="260" y="1572" as="geometry" />
        </mxCell>
        <mxCell id="241" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;snapToPoint=0;" value="Client-visible impact: brief TCP reconnect at T~1-2s only. The 40-60s pod rescheduling window has no additional client impact because VIPs were already moved to Node 2 at T~1-2s and pods on Nodes 2+3 continued serving throughout." vertex="1">
          <mxGeometry height="28" width="1510" x="260" y="1604" as="geometry" />
        </mxCell>
