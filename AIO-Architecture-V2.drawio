        <mxCell id="ui-hdr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;align=center;" value="Hubble UI + CLI (operator access tools)" vertex="1">
          <mxGeometry height="26" width="548" x="1220" y="130" as="geometry" />
        </mxCell>
        <mxCell id="ui-content" parent="1" style="text;html=1;fontSize=11;align=left;fillColor=none;strokeColor=none;verticalAlign=top;" value="Hubble UI — web dashboard (Deployment in kube-system)&#xa;  Visual flow map — pods as nodes · flows as edges&#xa;  Filter by namespace · pod · verdict · protocol&#xa;  Port-forward to access: kubectl port-forward -n kube-system svc/hubble-ui 12000:80&#xa;  Access via browser: http://localhost:12000&#xa;&#xa;Hubble CLI — command line flow interrogation&#xa;  hubble observe — live flow stream&#xa;  hubble observe --namespace alt-system — filter by namespace&#xa;  hubble observe --verdict DROPPED — show only dropped flows&#xa;  hubble observe --to-pod azure-iot-operations/mqtt-broker — target specific pod&#xa;  hubble status — relay connectivity and node status" vertex="1">
          <mxGeometry height="180" width="536" x="1226" y="160" as="geometry" />
        </mxCell>
