← LineState/TN/DMTN/#          → SetNewLineState()&lt;br&gt;├── LETSStateService    ← Traceability/TN/DMTN/#       → UpdateMachineCycle()&lt;br&gt;├── LETSStateService    ← LineSettings/TN/DMTN/#       → UpdateLineSettings()&lt;br&gt;├── CurrentLineState    ← UpdateLineState/#             → UpdateCurrentState()&lt;br&gt;├── CurrentLineState    ← TagLineState/#                → RetagLineState()&lt;br&gt;├── CurrentLineState    ← ReloadLineInfo/#              → RefreshLineConfigOnly()&lt;br&gt;└── MQTTtoEventHub      ← KanbanShipStatus/#            → forward to Event Hubs&lt;br&gt;&lt;/code&gt;&lt;/pre&gt;&lt;p style=&quot;font-family: Helvetica; white-space: normal;&quot;&gt;&lt;strong&gt;&lt;br&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p style=&quot;font-family: Helvetica; white-space: normal;&quot;&gt;&lt;strong style=&quot;&quot;&gt;Broker:&lt;/strong&gt;&amp;nbsp;&lt;code style=&quot;&quot;&gt;20x-lnxmqtt-cl.dmtnprod.lan&lt;/code&gt;&amp;nbsp;–– VM-based, HA proxy clustered, no mTLS&lt;br&gt;&lt;strong style=&quot;&quot;&gt;Library:&lt;/strong&gt;&amp;nbsp;MQTTnet via&amp;nbsp;&lt;code style=&quot;&quot;&gt;MQTTClientService.cs&lt;/code&gt;&lt;br&gt;&lt;strong style=&quot;&quot;&gt;Logging path:&lt;/strong&gt;&amp;nbsp;IoT Basics → ClientLogger ––&amp;gt; Filebeat ––&amp;gt; ES ––&amp;gt; Graylog (does NOT go via MQTT)&lt;/p&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;&quot; size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;&quot; size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;&quot; size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;&quot; size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;&quot; size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;&quot; size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;&quot; size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;&quot; size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;&quot; size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;&quot; size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;&quot; size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;&quot; size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;&quot; size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;&quot; size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;&quot; size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;font size=&quot;3&quot;&gt;&lt;br style=&quot;text-align: left;&quot;&gt;&lt;/font&gt;&lt;p style=&quot;text-align: left;&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/p&gt;&lt;font size=&quot;3&quot;&gt;&lt;br style=&quot;text-align: left;&quot;&gt;&lt;/font&gt;&lt;p style=&quot;text-align: left;&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/p&gt;&lt;div&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;" vertex="1">
