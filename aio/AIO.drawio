        <mxCell id="OZm9z_edTWAgUUqV0pyF-4" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;h2&gt;&lt;span style=&quot;text-align: left; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/h2&gt;&lt;h2&gt;&lt;span style=&quot;text-align: left; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/h2&gt;&lt;h2&gt;&lt;span style=&quot;text-align: left; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/h2&gt;&lt;h2&gt;&lt;span style=&quot;text-align: left; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/h2&gt;&lt;h2&gt;&lt;span style=&quot;text-align: left; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/h2&gt;&lt;h2&gt;&lt;span style=&quot;text-align: left; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/h2&gt;&lt;h2&gt;&lt;span style=&quot;text-align: left; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/h2&gt;&lt;h2&gt;&lt;span style=&quot;text-align: left; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;Target State — AIO MQTT Broker (Single Instance)&lt;/font&gt;&lt;/span&gt;&lt;/h2&gt;&lt;div&gt;&lt;span style=&quot;text-align: left; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;h2&gt;&lt;p style=&quot;font-weight: 400; text-align: left;&quot;&gt;&lt;strong&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;Publishers (all internal to K3s cluster · alt-system namespace · mTLS):&lt;/font&gt;&lt;/strong&gt;&lt;/p&gt;&lt;pre style=&quot;font-weight: 400; text-align: left;&quot;&gt;&lt;code&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;├── ALT Core API        → Traceability/TN/DMTN/{Line}/{Proc}/{Mach}&lt;br&gt;├── ALT Core API        → TraceabilityV2/TN/DMTN/{Line}/{Proc}/{Mach}&lt;br&gt;├── ALT Core API        → ProcessRequest/TN/DMTN/{Line}/{Proc}/{Mach}&lt;br&gt;├── LETSStateService    → LineStateDown/TN/DMTN/{Line}&lt;br&gt;├── LETSStateService    → OEE/TN/DMTN/{Line}&lt;br&gt;├── CurrentLineState    → LineState/{LineID}/{Process}          ← 1s loop&lt;br&gt;├── HourlyAttainment    → HourlyAttainment/TN/DMTN/{Display}&lt;br&gt;├── HourlyAttainment    → HourlyAttainmentActTwo/{Line}&lt;br&gt;└── KanbanStorage       → KanbanShipStatus/{Line}&lt;br&gt;&lt;br&gt;&lt;br&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/h2&gt;&lt;h2&gt;&lt;p style=&quot;font-weight: 400; text-align: left;&quot;&gt;&lt;strong&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;Subscribers:&lt;/font&gt;&lt;/strong&gt;&lt;/p&gt;&lt;pre style=&quot;font-weight: 400; text-align: left;&quot;&gt;&lt;code&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;├── LETSStateService    ← LineState/TN/DMTN/#          → SetNewLineState()         (unchanged)&lt;br&gt;├── LETSStateService    ← Traceability/TN/DMTN/#       → UpdateMachineCycle()      (unchanged)&lt;br&gt;├── LETSStateService    ← LineSettings/TN/DMTN/#       → UpdateLineSettings()      (unchanged)&lt;br&gt;├── CurrentLineState    ← UpdateLineState/#             → UpdateCurrentState()      (unchanged)&lt;br&gt;├── CurrentLineState    ← TagLineState/#                → RetagLineState()          (unchanged)&lt;br&gt;├── CurrentLineState    ← ReloadLineInfo/#              → RefreshLineConfigOnly()   (unchanged)&lt;br&gt;│&lt;br&gt;│   ── MQTTtoEventHub RETIRED — replaced by AIO dataflows ──&lt;br&gt;│&lt;br&gt;├── AIO dataflows       ← Traceability/#                → Event Hubs (real-time telemetry)&lt;br&gt;├── AIO dataflows       ← TraceabilityV2/#              → ADLS Gen2 (archive · JSON book of record)&lt;br&gt;├── AIO dataflows       ← LineStateDown/#               → Event Grid (Andon fast-path · sub-second)&lt;br&gt;├── AIO dataflows       ← OEE/#                         → Event Hubs (operational metrics)&lt;br&gt;├── AIO dataflows       ← HourlyAttainment/#            → Event Hubs (production reporting)&lt;br&gt;└── AIO dataflows       ← KanbanShipStatus/#            → Event Hubs (replaces MQTTtoEventHub)&lt;br&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;font size=&quot;3&quot;&gt;&lt;br style=&quot;font-weight: 400; text-align: left;&quot;&gt;&lt;/font&gt;&lt;p style=&quot;font-weight: 400; text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;&lt;strong&gt;Broker:&lt;/strong&gt;&amp;nbsp;AIO MQTT broker ·&amp;nbsp;&lt;code&gt;aio-system&lt;/code&gt;&amp;nbsp;namespace · K3s cluster · MetalLB VIP&lt;br&gt;&lt;strong&gt;Security:&lt;/strong&gt;&amp;nbsp;mTLS — certificate per publisher client · topic-level authorisation&lt;br&gt;&lt;strong&gt;Logging path:&lt;/strong&gt;&amp;nbsp;IoT Basics → OTEL Collector → Loki / Azure Monitor (does NOT go via MQTT)&lt;/font&gt;&lt;/p&gt;&lt;/h2&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;text-align: left; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;text-align: left; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;text-align: left; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;text-align: left; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;text-align: left; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;text-align: left; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;text-align: left; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;text-align: left; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;text-align: left; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;text-align: left; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;text-align: left; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;text-align: left; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;h2&gt;&lt;p style=&quot;font-weight: 400; text-align: left;&quot;&gt;&lt;br&gt;&lt;/p&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;&lt;br style=&quot;font-weight: 400; text-align: left;&quot;&gt;&lt;/font&gt;&lt;p style=&quot;font-weight: 400; text-align: left;&quot;&gt;&lt;br&gt;&lt;/p&gt;&lt;/h2&gt;" vertex="1">
